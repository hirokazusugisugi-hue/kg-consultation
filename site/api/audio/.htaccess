# 音声ファイルディレクトリへの直接アクセスを禁止
# download.php 経由でのみアクセス可能にする

<IfModule mod_rewrite.c>
    RewriteEngine On

    # files/ ディレクトリへの直接アクセスを禁止
    RewriteRule ^files/ - [F,L]
</IfModule>

# files/ ディレクトリ内のファイル一覧を禁止
Options -Indexes

# PHPファイルへのアクセスは許可（upload.php, download.php, trigger_transcribe.php）
<FilesMatch "\.(php)$">
    Order Allow,Deny
    Allow from all
</FilesMatch>

# .py ファイルへの直接アクセスを禁止
<FilesMatch "\.(py)$">
    Order Deny,Allow
    Deny from all
</FilesMatch>

# config.php への直接アクセスを禁止
<Files "config.php">
    Order Deny,Allow
    Deny from all
</Files>

# check_env.php への直接アクセスを禁止（トークン認証は内部で実装）
# ※環境チェック完了後、check_env.phpは削除すること

# PHP設定（Apache mod_php の場合）
<IfModule mod_php.c>
    php_value upload_max_filesize 100M
    php_value post_max_size 100M
    php_value max_execution_time 300
    php_value max_input_time 300
    php_value memory_limit 256M
</IfModule>
